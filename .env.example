# Environment variables for LLMapperino

# Ontox MINERVA API token (optional, if anonymous login fails)
# MINERVA_TOKEN="your_minerva_token_here"

# OpenRouter API key (can be used for Perplexity and OpenAI models)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Optional ONTOX user and password (defaults to anonymous)
# ONTOX_USER=anonymous
# ONTOX_PASS=
